            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "ต้องรันต่อจาก 'Register (setup สำหรับเทส Unverified Login)' ทันที",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{unverified_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Register (setup สำหรับเทส OTP ผิด)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('otp_negative_email', 'pmtest-otpneg-' + Date.now() + '@test.example');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.dev_otp) pm.environment.set('otp_negative_dev_otp', json.dev_otp);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "สมัครสมาชิกใหม่แยกต่างหาก กัน attempt_count ปนกับ test อื่น",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{otp_negative_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Verify OTP - รหัสผิด (400)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// เผื่อ dev_otp สุ่มได้ตรงกับ 000000 พอดี (โอกาสน้อยมาก แต่กันไว้)",
                  "const realOtp = pm.environment.get('otp_negative_dev_otp');",
                  "pm.environment.set('wrong_otp_code', realOtp === '000000' ? '111111' : '000000');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
