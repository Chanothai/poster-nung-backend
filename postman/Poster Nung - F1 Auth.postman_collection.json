                "type": "text/javascript",
                "exec": [
                  "// CLAUDE.md Global Rule 5: /auth/login ต้องมี rate-limit",
                  "// limiter ตั้งไว้ 5/minute ต่อ IP (app/api/v1/auth.py) — ครั้งที่ 6 ขึ้นไปในนาทีเดียวกันต้องโดน 429",
                  "const code = pm.response.code;",
                  "pm.test('status เป็น 401 (ยังไม่ครบ limit) หรือ 429 (ครบ limit แล้ว)', () => {",
                  "    pm.expect([401, 429]).to.include(code);",
                  "});",
                  "",
                  "if (code === 429) {",
                  "    const json = pm.response.json();",
                  "    pm.test('error_code = LOGIN_RATE_LIMITED', () => pm.expect(json.error_code).to.eql('LOGIN_RATE_LIMITED'));",
                  "    pm.test('มี Retry-After header', () => pm.expect(pm.response.headers.has('Retry-After')).to.be.true);",
                  "    console.log('Retry-After:', pm.response.headers.get('Retry-After'), 'seconds');",
                  "}"
                ]
