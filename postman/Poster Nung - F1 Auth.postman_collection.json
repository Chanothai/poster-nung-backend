{
  "info": {
    "_postman_id": "ac5b6c26-ea89-4748-9766-95915870e88b",
    "name": "Poster Nung - F1 Authentication",
    "description": "Collection ทดสอบ F1 Authentication API ของ Poster Nung Backend\n\nอ้างอิงจาก docs/openapi.yaml และ docs/api-contract-f1-f3.md (source of truth)\n\n**ก่อนใช้:**\n1. Import environment 'Poster Nung - Local.postman_environment.json' คู่กัน แล้วเลือกเป็น active environment\n2. เช็คว่า backend รันอยู่ที่ port ตรงกับ base_url ในไฟล์ environment (default: http://127.0.0.1:8000)\n3. ต้องตั้ง DEBUG=true ใน .env ของ backend ไม่งั้น response register จะไม่มี dev_otp ให้ใช้ต่อ\n\n**โครงสร้าง:**\n- 01 - Happy Path: รันเรียงลำดับ 1→4 (สมัคร → verify → login → refresh)\n- 02 - Negative Cases: เทส error code ต่างๆ ตาม error catalog — บาง request ต้องรันต่อจาก request อื่นก่อน (ดู Description ของแต่ละอัน)\n- 03 - Rate Limit: ต้องใช้ Collection Runner ยิงซ้ำ 6 รอบ (Postman เดี่ยวๆ ยิง burst ไม่ได้)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Happy Path (รันตามลำดับ 1→4)",
      "description": "Flow ปกติของ F1: สมัคร → ยืนยัน OTP → login → refresh token\nต้องรันเรียงลำดับ 1-4 เพราะแต่ละ request ใช้ตัวแปรจาก request ก่อนหน้า (test_email, dev_otp, access_token, refresh_token)",
      "item": [
        {
          "name": "1. Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// สร้าง email ใหม่ทุกครั้งที่รัน กัน 409 EMAIL_ALREADY_REGISTERED ตอนรันซ้ำ",
                  "pm.environment.set('test_email', 'pmtest-' + Date.now() + '@test.example');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('response ไม่มี hashed_password หลุดออกมา (CLAUDE.md Global Rule 1)', () => {",
                  "    pm.expect(json).to.not.have.property('hashed_password');",
                  "});",
                  "pm.test('is_verified เริ่มต้นเป็น false', () => pm.expect(json.is_verified).to.eql(false));",
                  "pm.test('email ตรงกับที่ส่งไป', () => pm.expect(json.email).to.eql(pm.environment.get('test_email')));",
                  "",
                  "pm.environment.set('user_id', json.id);",
                  "",
                  "if (json.dev_otp) {",
                  "    pm.test('dev_otp เป็นเลข 6 หลัก (DEBUG=true)', () => pm.expect(json.dev_otp).to.match(/^\\d{6}$/));",
                  "    pm.environment.set('dev_otp', json.dev_otp);",
                  "} else {",
                  "    console.warn('ไม่มี dev_otp ใน response — เช็คว่า DEBUG=true ใน .env ของ backend หรือยัง ไม่งั้น step ถัดไป (Verify OTP) จะ fail');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "สมัครสมาชิกใหม่ — pre-request script สร้าง email unique ทุกครั้งกันชนกับ 409 ตอนรันซ้ำ\nต้องตั้ง DEBUG=true ใน .env ของ backend ไม่งั้นจะไม่มี dev_otp ให้ใช้ต่อใน step 2",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\",\n  \"phone\": \"0812345678\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "2. Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('ได้ access_token และ refresh_token', () => {",
                  "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.refresh_token).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.token_type).to.eql('bearer');",
                  "});",
                  "",
                  "pm.environment.set('access_token', json.access_token);",
                  "pm.environment.set('refresh_token', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/verify-otp",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "verify-otp"
              ]
            },
            "description": "ใช้ dev_otp ที่ได้จาก step 1 — verify ผ่าน = auto-login ออก JWT ทันทีตาม docs/openapi.yaml",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"code\": \"{{dev_otp}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "3. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('ได้ token ชุดใหม่', () => {",
                  "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.refresh_token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.environment.set('access_token', json.access_token);",
                  "pm.environment.set('refresh_token', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "ต้องรันหลัง Verify OTP แล้วเท่านั้น (account ต้อง is_verified=true ก่อน ไม่งั้นได้ 403 ACCOUNT_NOT_VERIFIED)",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "4. Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('ได้ access/refresh token ชุดใหม่ (rotate)', () => {",
                  "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.refresh_token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.environment.set('access_token', json.access_token);",
                  "pm.environment.set('refresh_token', json.refresh_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "refresh token เก่าจะถูก revoke ทันที (rotate) — เรียกซ้ำด้วย token เก่าจะได้ 401 REFRESH_TOKEN_INVALID",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 - Negative Cases",
      "description": "ทดสอบ error path ตาม docs/api-contract-f1-f3.md §3 (error code catalog)\nSelf-contained — กด 'Run folder' รันทั้งโฟลเดอร์นี้เดี่ยวๆ ได้เลย ไม่ต้องรัน 01 ก่อน (มี setup request ของตัวเองอยู่ในนี้แล้ว)\nยกเว้น 'Verify OTP - โค้ดหมดอายุ' ที่ต้องรอจริง 10+ นาทีถึงจะเทสได้แม่นยำ (รันเร็วๆ ได้ปกติไม่ fail แค่ไม่ได้เทสสถานการณ์จริง)",
      "item": [
        {
          "name": "0. Register (setup สำหรับ Duplicate Email + Wrong Password)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('neg_email', 'pmtest-neg-' + Date.now() + '@test.example');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "สมัครสมาชิกแยกต่างหากสำหรับ folder นี้โดยเฉพาะ ไม่พึ่ง {{test_email}} จาก '01 - Happy Path' — ทำให้รัน folder นี้เดี่ยวๆ ได้เลย",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{neg_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Register - Duplicate Email (409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 409', () => pm.response.to.have.status(409));",
                  "const json = pm.response.json();",
                  "pm.test('error_code = EMAIL_ALREADY_REGISTERED', () => {",
                  "    pm.expect(json.error_code).to.eql('EMAIL_ALREADY_REGISTERED');",
                  "});",
                  "pm.test('response เป็น custom error envelope (error_code/message/details)', () => {",
                  "    pm.expect(json).to.have.all.keys('error_code', 'message', 'details');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "รันต่อจาก '0. Register (setup)' ในโฟลเดอร์นี้เอง (ใช้ {{neg_email}} เดิมที่สมัครไปแล้ว) — ไม่ต้องพึ่ง folder 01",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{neg_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Register - Invalid Data (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 422', () => pm.response.to.have.status(422));",
                  "const json = pm.response.json();",
                  "pm.test('error_code = VALIDATION_ERROR', () => pm.expect(json.error_code).to.eql('VALIDATION_ERROR'));",
                  "pm.test('details เป็น array และมี field/message', () => {",
                  "    pm.expect(json.details).to.be.an('array').that.is.not.empty;",
                  "    pm.expect(json.details[0]).to.have.all.keys('field', 'message');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "email ผิดรูปแบบ + password สั้นกว่า 8 ตัว — คาด 422 พร้อม details ครบทั้ง 2 field",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"short\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Login - Wrong Password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "const json = pm.response.json();",
                  "pm.test('error_code = INVALID_CREDENTIALS', () => pm.expect(json.error_code).to.eql('INVALID_CREDENTIALS'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "รันต่อจาก '0. Register (setup)' ในโฟลเดอร์นี้ (ใช้ {{neg_email}} ที่มีอยู่จริง แต่ password ผิด) — ไม่ต้องพึ่ง folder 01",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{neg_email}}\",\n  \"password\": \"{{wrong_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Login - Email ไม่มีในระบบ (401 เหมือนกัน กัน enumeration)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401', () => pm.response.to.have.status(401));",
                  "const json = pm.response.json();",
                  "pm.test('error_code เหมือนกับกรณี password ผิด (กัน user enumeration)', () => {",
                  "    pm.expect(json.error_code).to.eql('INVALID_CREDENTIALS');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "ยืนยันว่า email ไม่มีในระบบ กับ password ผิด ได้ error message เดียวกันเป๊ะ — สำคัญเพื่อกัน user enumeration attack",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"no-such-user-{{$timestamp}}@test.example\",\n  \"password\": \"{{wrong_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Register (setup สำหรับเทส Unverified Login)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('unverified_email', 'pmtest-unverified-' + Date.now() + '@test.example');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "// ตั้งใจไม่ verify OTP ต่อ — เอาไว้เทส login ตอนยังไม่ verify"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "สมัครสมาชิกใหม่แต่ไม่ verify OTP ต่อ — ใช้เป็น setup ให้ request ถัดไป",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{unverified_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Login - Account ยังไม่ Verify OTP (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 403', () => pm.response.to.have.status(403));",
                  "const json = pm.response.json();",
                  "pm.test('error_code = ACCOUNT_NOT_VERIFIED', () => pm.expect(json.error_code).to.eql('ACCOUNT_NOT_VERIFIED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
