# ============================================
# .env.example — คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
#   cp .env.example .env
# ไฟล์นี้ commit เข้า git ได้ (ไม่มี secret จริง)
# ส่วนไฟล์ .env ห้าม commit เด็ดขาด (อยู่ใน .gitignore แล้ว)
# ============================================

# ---- PostgreSQL (ใช้โดย docker-compose.yml) ----
POSTGRES_USER=poster_app
POSTGRES_PASSWORD=changeme_in_local
POSTGRES_DB=poster_db
POSTGRES_PORT=5432

# ---- Database connection string (ใช้โดย FastAPI / SQLAlchemy) ----
# รูปแบบ: postgresql+asyncpg://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>
# host เป็น localhost เพราะ docker map port ออกมาที่เครื่องแล้ว
DATABASE_URL=postgresql+asyncpg://poster_app:changeme_in_local@localhost:5432/poster_db

# ---- JWT / Auth ----
# สร้างค่าใหม่ด้วย: openssl rand -hex 32
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ---- Environment (required) — sit / uat / production ----
# แอปจะ fail fast ถ้าขาดค่านี้ หรือใส่ค่านอกเหนือ 3 ตัวนี้
# production: ระบบบังคับ DEBUG=false + DOCS_ENABLED=false (config validator)
ENVIRONMENT=sit

# ---- OTP / Rate-limit (Global Rule 5) ----
OTP_RATE_LIMIT_PER_10MIN=5
OTP_MAX_ATTEMPTS=5

# ---- Reservation TTL (F3) ----
RESERVE_TTL_MINUTES=15

# ---- Firebase / Social login ----
# Firebase project id ที่ mobile ใช้ (project เดียวกันทุก env: sit/uat/production)
# เป็น audience ของ Firebase ID token ที่ backend verify — ไม่ใช่ secret (public)
# ว่างได้ตอน local dev ถ้ายังไม่ทดสอบ social login (endpoint จะคืน 503)
FIREBASE_PROJECT_ID=posternung
# Firebase service account credential — **secret** ได้จาก Firebase console → Project
# settings → Service accounts → Generate new private key. ตั้งได้ 1 ใน 2 ทาง (PATH มาก่อน):
#
# ทางเลือก A (prod, best practice): ชี้ path ไฟล์ JSON ใน container — key ไม่อยู่ใน env
#   (ไม่โผล่ใน docker inspect/env dump). ใช้คู่กับ read-only bind-mount ใน
#   docker-compose.production.yml → ต้องตั้ง FIREBASE_SA_HOST_PATH (path บน host) ด้วย
# FIREBASE_SERVICE_ACCOUNT_PATH=
# FIREBASE_SA_HOST_PATH=          # (prod เท่านั้น) absolute path ไฟล์ JSON บน host สำหรับ bind-mount
#
# ทางเลือก B (dev/test): เนื้อ JSON ทั้งก้อนเป็น string บรรทัดเดียว (เช่น '{"type":...}')
# firebase-admin ใช้ verify Firebase ID token (+ check_revoked) — ตั้งครบ 0 ทาง → endpoint คืน 503
# ห้าม commit ค่าจริง (ไฟล์ .env จริง gitignored อยู่แล้ว)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:3000

# ---- App ----
DEBUG=true
DOCS_ENABLED=true

# ---- Container image (ใช้โดย docker-compose ตอน deploy — CI ตั้งเป็น git sha) ----
# local dev ปล่อยว่างได้ (default = posternung:local)
IMAGE_REGISTRY=
IMAGE_TAG=

# ---- Payment provider (ใส่ค่าจริงเฉพาะตอนทำ feature payment) ----
# ห้าม hardcode secret key ในโค้ด — อ่านจาก env นี้เท่านั้น
STRIPE_SECRET_KEY=
OMISE_SECRET_KEY=
