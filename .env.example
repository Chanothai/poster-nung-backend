# ============================================
# .env.example — คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
#   cp .env.example .env
# ไฟล์นี้ commit เข้า git ได้ (ไม่มี secret จริง)
# ส่วนไฟล์ .env ห้าม commit เด็ดขาด (อยู่ใน .gitignore แล้ว)
# ============================================

# ---- PostgreSQL (ใช้โดย docker-compose.yml) ----
POSTGRES_USER=poster_app
POSTGRES_PASSWORD=changeme_in_local
POSTGRES_DB=poster_db
POSTGRES_PORT=5432

# ---- Database connection string (ใช้โดย FastAPI / SQLAlchemy) ----
# รูปแบบ: postgresql+asyncpg://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>
# host เป็น localhost เพราะ docker map port ออกมาที่เครื่องแล้ว
DATABASE_URL=postgresql+asyncpg://poster_app:changeme_in_local@localhost:5432/poster_db

# ---- JWT / Auth ----
# สร้างค่าใหม่ด้วย: openssl rand -hex 32
JWT_SECRET=replace_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ---- App ----
DEBUG=true

# ---- Payment provider (ใส่ค่าจริงเฉพาะตอนทำ feature payment) ----
# ห้าม hardcode secret key ในโค้ด — อ่านจาก env นี้เท่านั้น
STRIPE_SECRET_KEY=
OMISE_SECRET_KEY=
